rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public read for client-side operations ───
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /skus/{skuId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /combos/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /loyaltyAccounts/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /loyaltyTransactions/{doc} {
      allow read: if true;
      allow create: if true;
      allow write: if request.auth != null;
    }
    match /publicCatalogCache/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Authenticated admin access ───
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
